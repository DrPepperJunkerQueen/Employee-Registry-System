<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ButtonBar?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.MenuButton?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Text?>

<VBox alignment="CENTER" spacing="20.0" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.ersapp.EmployeeAppController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>

    <Label fx:id="welcomeText" />
    <ButtonBar prefHeight="40.0">
      <buttons>
         <ButtonBar prefHeight="40.0" prefWidth="600.0">
           <buttons>
             <Button fx:id="sendToSpringBootButton" prefHeight="23.0" prefWidth="200.0" mnemonicParsing="false" text="Send to SpringBoot" />
                  <Button fx:id="exportToCSVButton" prefHeight="23.0" prefWidth="200.0" mnemonicParsing="false" text="Export to CSV" />
           </buttons>
         </ButtonBar>
      </buttons>
    </ButtonBar>
    <ButtonBar prefHeight="40.0" prefWidth="200.0">
        <buttons>
            <TextField fx:id="addEmployeeGroupNameTextField" prefHeight="23.0" prefWidth="150.0" promptText="Employee Group Name" />
            <TextField fx:id="addEmployeeGroupCapacityTextField" prefHeight="23.0" prefWidth="150.0" promptText="Group Capacity" />
            <Button fx:id="addEmployeeGroupButton" mnemonicParsing="false" text="Add Employee Group" />
        </buttons>
    </ButtonBar>
   <ButtonBar prefHeight="40.0" prefWidth="200.0">
     <buttons>
         <Text strokeType="OUTSIDE" strokeWidth="0.0" text="Sort Employee Group Menu by:" />
         <Button fx:id="sortByNameButton" mnemonicParsing="false" text="Name" />
         <Button fx:id="sortByEmployeeNumberButton" mnemonicParsing="false" text="Employee Number" />
       <Button fx:id="sortByFillPercentageButton" mnemonicParsing="false" text="Fill Percentage" />
     </buttons>
   </ButtonBar>
    <ButtonBar prefHeight="40.0" prefWidth="200.0">
        <buttons>
         <TextField fx:id="searchEmployeeByLastNameTextField" prefHeight="23.0" prefWidth="200.0" promptText="Search Employee by Last Name" />
            <Button fx:id="removeEmployeeGroupButton" mnemonicParsing="false" text="Remove Employee Group" />
            <MenuButton fx:id="showEmployeeGroup" mnemonicParsing="false" text="Employee Group" textAlignment="CENTER">
                <items>
                    <MenuItem mnemonicParsing="false" text="Action 1" />
                    <MenuItem mnemonicParsing="false" text="Action 2" />
                </items>
            </MenuButton>
            <Button fx:id="addEmployeeButton" mnemonicParsing="false" text="Add Employee" />
        </buttons>
    </ButtonBar>
    <Text fx:id="fillPercentage" strokeType="OUTSIDE" strokeWidth="0.0" text="Fill Percenteage:" />
    <TableView fx:id="employeeTable" editable="true" prefHeight="200.0" prefWidth="627.0">
        <columns>
            <TableColumn fx:id="idColumn" prefWidth="150.0" text="ID" />
            <TableColumn fx:id="firstNameColumn" prefWidth="150.0" text="First Name" />
            <TableColumn fx:id="lastNameColumn" prefWidth="150.0" text="Last Name" />
            <TableColumn fx:id="conditionColumn" prefWidth="150.0" text="Condition" />
            <TableColumn fx:id="birthYearColumn" prefWidth="150.0" text="Birth Year" />
            <TableColumn fx:id="salaryColumn" prefWidth="150.0" text="Salary" />
            <TableColumn fx:id="removeColumn" prefWidth="150.0" text="Remove Employee" />
        </columns>
    </TableView>
   <ButtonBar prefHeight="40.0" prefWidth="200.0">
     <buttons>
       <Button fx:id="addRateButton" mnemonicParsing="false" text="Add Rate" />
     </buttons>
   </ButtonBar>
    <Text fx:id="averageGradeText" strokeType="OUTSIDE" strokeWidth="0.0" text="Average Grade:" />
   <TableView fx:id="rateTable" editable="true" prefHeight="200.0" prefWidth="200.0">
     <columns>
         <TableColumn fx:id="groupNameColumn" prefWidth="150.0" text="Group" />
         <TableColumn fx:id="rateIDColumn" prefWidth="150.0" text="ID" />
       <TableColumn fx:id="gradeColumn" prefWidth="150.0" text="Grade" />
       <TableColumn fx:id="dateColumn" prefWidth="150.0" text="Date" />
         <TableColumn fx:id="commentColumn" prefWidth="300.0" text="Comment" />
         <TableColumn fx:id="removeRateColumn" prefWidth="150.0" text="Remove Rate" />
     </columns>
   </TableView>
    <TableView fx:id="statsTable" prefHeight="200.0" prefWidth="627.0">
        <columns>
            <TableColumn fx:id="groupNameColumnStats" prefWidth="150.0" text="Group" />
            <TableColumn fx:id="countColumn" prefWidth="150.0" text="Number of Ratings" />
            <TableColumn fx:id="averageColumn" prefWidth="150.0" text="Average Rating" />
        </columns>
    </TableView>
</VBox>
